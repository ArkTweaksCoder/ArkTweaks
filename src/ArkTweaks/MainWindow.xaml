<Window x:Class="ArkTweaks.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:ArkTweaks.UI.Navigation"
        Title="Ark Optimizer" 
        Height="820" 
        Width="1280"
        MinHeight="820"
        MinWidth="1280"
        Background="{StaticResource PrimaryBackground}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize">
    
    <WindowChrome.WindowChrome>
        <WindowChrome 
            CaptionHeight="0"
            ResizeBorderThickness="5"
            UseAeroCaptionButtons="False"
            NonClientFrameEdges="None" />
    </WindowChrome.WindowChrome>

    <Border Background="{StaticResource PrimaryBackground}"
            CornerRadius="12"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom Title Bar -->
            <Grid Grid.Row="0" 
                  Height="48" 
                  Background="{StaticResource SecondaryBackground}"
                  MouseLeftButtonDown="OnTitleBarMouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Logo and Title -->
                <StackPanel Grid.Column="0" 
                           Orientation="Horizontal" 
                           Margin="16,0">
                    <TextBlock Text="🧠" 
                               FontSize="20" 
                               Margin="0,0,8,0"/>
                    <TextBlock Text="Ark Optimizer" 
                               Style="{StaticResource CardTitleTextStyle}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Window Controls -->
                <StackPanel Grid.Column="2" 
                          Orientation="Horizontal">
                    <Button x:Name="MinimizeButton"
                            Content="─"
                            Width="46"
                            Height="32"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{StaticResource SecondaryTextBrush}"
                            FontSize="16"
                            Cursor="Hand"
                            Click="OnMinimizeClick">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    Padding="12,8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource HoverBrush}" />
                                        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button x:Name="MaximizeButton"
                            Content="□"
                            Width="46"
                            Height="32"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{StaticResource SecondaryTextBrush}"
                            FontSize="14"
                            Cursor="Hand"
                            Click="OnMaximizeClick">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    Padding="12,8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="{StaticResource HoverBrush}" />
                                        <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>

                    <Button x:Name="CloseButton"
                            Content="✕"
                            Width="46"
                            Height="32"
                            Background="Transparent"
                            BorderThickness="0"
                            Foreground="{StaticResource SecondaryTextBrush}"
                            FontSize="16"
                            Cursor="Hand"
                            Click="OnCloseClick">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}"
                                                    Padding="12,8">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#FF5A67" />
                                        <Setter Property="Foreground" Value="White" />
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Main Content -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0" 
                        Background="{StaticResource SidebarBackground}"
                        BorderBrush="{StaticResource SeparatorBrush}"
                        BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Navigation -->
                        <StackPanel Grid.Row="0" Margin="8,16">
                            <!-- Logo Section -->
                            <StackPanel Margin="16,0,16,24">
                                <TextBlock Text="🧠 Ark Optimizer"
                                           Style="{StaticResource SectionHeaderTextStyle}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="v1.0.0"
                                           Style="{StaticResource SmallLabelTextStyle}"
                                           Foreground="{StaticResource MutedTextBrush}"/>
                            </StackPanel>

                            <!-- Navigation Items -->
                            <RadioButton GroupName="Navigation"
                                        Content="Dashboard"
                                        IsChecked="True"
                                        Click="OnNavButtonClick"
                                        Template="{StaticResource NavigationItemTemplate}">
                                <RadioButton.Tag>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📊" FontSize="18" Margin="0,0,12,0"/>
                                        <TextBlock Text="Dashboard"/>
                                    </StackPanel>
                                </RadioButton.Tag>
                            </RadioButton>

                            <RadioButton GroupName="Navigation"
                                        Content="Optimize"
                                        Click="OnNavButtonClick"
                                        Template="{StaticResource NavigationItemTemplate}">
                                <RadioButton.Tag>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚡" FontSize="18" Margin="0,0,12,0"/>
                                        <TextBlock Text="Optimize"/>
                                    </StackPanel>
                                </RadioButton.Tag>
                            </RadioButton>

                            <RadioButton GroupName="Navigation"
                                        Content="Cleanup"
                                        Click="OnNavButtonClick"
                                        Template="{StaticResource NavigationItemTemplate}">
                                <RadioButton.Tag>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🧹" FontSize="18" Margin="0,0,12,0"/>
                                        <TextBlock Text="Cleanup"/>
                                    </StackPanel>
                                </RadioButton.Tag>
                            </RadioButton>

                            <RadioButton GroupName="Navigation"
                                        Content="Startup"
                                        Click="OnNavButtonClick"
                                        Template="{StaticResource NavigationItemTemplate}">
                                <RadioButton.Tag>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🚀" FontSize="18" Margin="0,0,12,0"/>
                                        <TextBlock Text="Startup"/>
                                    </StackPanel>
                                </RadioButton.Tag>
                            </RadioButton>

                            <RadioButton GroupName="Navigation"
                                        Content="Gaming"
                                        Click="OnNavButtonClick"
                                        Template="{StaticResource NavigationItemTemplate}">
                                <RadioButton.Tag>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🎮" FontSize="18" Margin="0,0,12,0"/>
                                        <TextBlock Text="Gaming"/>
                                    </StackPanel>
                                </RadioButton.Tag>
                            </RadioButton>

                            <RadioButton GroupName="Navigation"
                                        Content="Performance"
                                        Click="OnNavButtonClick"
                                        Template="{StaticResource NavigationItemTemplate}">
                                <RadioButton.Tag>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📈" FontSize="18" Margin="0,0,12,0"/>
                                        <TextBlock Text="Performance"/>
                                    </StackPanel>
                                </RadioButton.Tag>
                            </RadioButton>

                            <RadioButton GroupName="Navigation"
                                        Content="Restore"
                                        Click="OnNavButtonClick"
                                        Template="{StaticResource NavigationItemTemplate}">
                                <RadioButton.Tag>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔁" FontSize="18" Margin="0,0,12,0"/>
                                        <TextBlock Text="Restore"/>
                                    </StackPanel>
                                </RadioButton.Tag>
                            </RadioButton>

                            <RadioButton GroupName="Navigation"
                                        Content="History"
                                        Click="OnNavButtonClick"
                                        Template="{StaticResource NavigationItemTemplate}">
                                <RadioButton.Tag>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📜" FontSize="18" Margin="0,0,12,0"/>
                                        <TextBlock Text="History"/>
                                    </StackPanel>
                                </RadioButton.Tag>
                            </RadioButton>

                            <RadioButton GroupName="Navigation"
                                        Content="Logs"
                                        Click="OnNavButtonClick"
                                        Template="{StaticResource NavigationItemTemplate}">
                                <RadioButton.Tag>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📋" FontSize="18" Margin="0,0,12,0"/>
                                        <TextBlock Text="Logs"/>
                                    </StackPanel>
                                </RadioButton.Tag>
                            </RadioButton>
                        </StackPanel>

                        <!-- Bottom Utility Section -->
                        <StackPanel Grid.Row="1" Margin="8,0,8,16">
                            <Border Background="{StaticResource ElevatedCardBackground}"
                                    CornerRadius="8"
                                    Padding="12"
                                    Margin="8,8,8,4">
                                <StackPanel>
                                    <TextBlock Text="Free License"
                                               Style="{StaticResource SmallLabelTextStyle}"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="Upgrade to Pro"
                                               Style="{StaticResource SmallLabelTextStyle}"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <RadioButton GroupName="Navigation"
                                        Content="Settings"
                                        Click="OnNavButtonClick"
                                        Template="{StaticResource NavigationItemTemplate}">
                                <RadioButton.Tag>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚙️" FontSize="18" Margin="0,0,12,0"/>
                                        <TextBlock Text="Settings"/>
                                    </StackPanel>
                                </RadioButton.Tag>
                            </RadioButton>

                            <RadioButton GroupName="Navigation"
                                        Content="About"
                                        Click="OnNavButtonClick"
                                        Template="{StaticResource NavigationItemTemplate}">
                                <RadioButton.Tag>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="ℹ️" FontSize="18" Margin="0,0,12,0"/>
                                        <TextBlock Text="About"/>
                                    </StackPanel>
                                </RadioButton.Tag>
                            </RadioButton>

                            <!-- External Links -->
                            <StackPanel Orientation="Horizontal" 
                                       HorizontalAlignment="Center"
                                       Margin="0,16,0,0">
                                <Button Width="36" Height="36"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="8"
                                        Cursor="Hand"
                                        Template="{StaticResource IconButtonTemplate}"
                                        ToolTip="Discord">
                                    <TextBlock Text="💬" FontSize="16"/>
                                </Button>
                                <Button Width="36" Height="36"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="8"
                                        Cursor="Hand"
                                        Template="{StaticResource IconButtonTemplate}"
                                        ToolTip="Website">
                                    <TextBlock Text="🌐" FontSize="16"/>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Main Content Area -->
                <Border Grid.Column="1" 
                        Background="{StaticResource PrimaryBackground}"
                        Padding="32">
                    <ContentControl x:Name="ContentArea"/>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>