<Window x:Class="ArkTweaks.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:ArkTweaks.UI.Navigation"
        Title="Ark Tweaks" 
        Height="700" 
        Width="1200"
        MinHeight="600"
        MinWidth="1000"
        Background="#1E1E1E"
        WindowStartupLocation="CenterScreen">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

                <!-- Sidebar -->
                <Border Grid.Column="0" 
                        Background="{StaticResource SidebarBackground}"
                        BorderBrush="{StaticResource SeparatorBrush}"
                        BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Navigation -->
                        <StackPanel Grid.Row="0" Margin="8,16">
                            <!-- Logo Section -->
                            <StackPanel Margin="16,0,16,24">
                                <TextBlock Text="🧠 Ark Optimizer"
                                           Style="{StaticResource SectionHeaderTextStyle}"
                                           Margin="0,0,0,4"/>
                                <TextBlock Text="v1.0.0"
                                           Style="{StaticResource SmallLabelTextStyle}"
                                           Foreground="{StaticResource MutedTextBrush}"/>
                            </StackPanel>

                            <!-- Navigation Items -->
                            <RadioButton GroupName="Navigation"
                                        Content="Dashboard"
                                        IsChecked="True"
                                        Click="OnNavButtonClick"
                                        Template="{StaticResource NavigationItemTemplate}">
                                <RadioButton.Tag>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📊" FontSize="18" Margin="0,0,12,0"/>
                                        <TextBlock Text="Dashboard"/>
                                    </StackPanel>
                                </RadioButton.Tag>
                            </RadioButton>

                            <RadioButton GroupName="Navigation"
                                        Content="Optimize"
                                        Click="OnNavButtonClick"
                                        Template="{StaticResource NavigationItemTemplate}">
                                <RadioButton.Tag>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚡" FontSize="18" Margin="0,0,12,0"/>
                                        <TextBlock Text="Optimize"/>
                                    </StackPanel>
                                </RadioButton.Tag>
                            </RadioButton>

                            <RadioButton GroupName="Navigation"
                                        Content="Cleanup"
                                        Click="OnNavButtonClick"
                                        Template="{StaticResource NavigationItemTemplate}">
                                <RadioButton.Tag>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🧹" FontSize="18" Margin="0,0,12,0"/>
                                        <TextBlock Text="Cleanup"/>
                                    </StackPanel>
                                </RadioButton.Tag>
                            </RadioButton>

                            <RadioButton GroupName="Navigation"
                                        Content="Startup"
                                        Click="OnNavButtonClick"
                                        Template="{StaticResource NavigationItemTemplate}">
                                <RadioButton.Tag>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🚀" FontSize="18" Margin="0,0,12,0"/>
                                        <TextBlock Text="Startup"/>
                                    </StackPanel>
                                </RadioButton.Tag>
                            </RadioButton>

                            <RadioButton GroupName="Navigation"
                                        Content="Gaming"
                                        Click="OnNavButtonClick"
                                        Template="{StaticResource NavigationItemTemplate}">
                                <RadioButton.Tag>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🎮" FontSize="18" Margin="0,0,12,0"/>
                                        <TextBlock Text="Gaming"/>
                                    </StackPanel>
                                </RadioButton.Tag>
                            </RadioButton>

                            <RadioButton GroupName="Navigation"
                                        Content="Performance"
                                        Click="OnNavButtonClick"
                                        Template="{StaticResource NavigationItemTemplate}">
                                <RadioButton.Tag>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📈" FontSize="18" Margin="0,0,12,0"/>
                                        <TextBlock Text="Performance"/>
                                    </StackPanel>
                                </RadioButton.Tag>
                            </RadioButton>

                            <RadioButton GroupName="Navigation"
                                        Content="Restore"
                                        Click="OnNavButtonClick"
                                        Template="{StaticResource NavigationItemTemplate}">
                                <RadioButton.Tag>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="🔁" FontSize="18" Margin="0,0,12,0"/>
                                        <TextBlock Text="Restore"/>
                                    </StackPanel>
                                </RadioButton.Tag>
                            </RadioButton>

                            <RadioButton GroupName="Navigation"
                                        Content="History"
                                        Click="OnNavButtonClick"
                                        Template="{StaticResource NavigationItemTemplate}">
                                <RadioButton.Tag>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📜" FontSize="18" Margin="0,0,12,0"/>
                                        <TextBlock Text="History"/>
                                    </StackPanel>
                                </RadioButton.Tag>
                            </RadioButton>

                            <RadioButton GroupName="Navigation"
                                        Content="Logs"
                                        Click="OnNavButtonClick"
                                        Template="{StaticResource NavigationItemTemplate}">
                                <RadioButton.Tag>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="📋" FontSize="18" Margin="0,0,12,0"/>
                                        <TextBlock Text="Logs"/>
                                    </StackPanel>
                                </RadioButton.Tag>
                            </RadioButton>
                        </StackPanel>

                        <!-- Bottom Utility Section -->
                        <StackPanel Grid.Row="1" Margin="8,0,8,16">
                            <Border Background="{StaticResource ElevatedCardBackground}"
                                    CornerRadius="8"
                                    Padding="12"
                                    Margin="8,8,8,4">
                                <StackPanel>
                                    <TextBlock Text="Free License"
                                               Style="{StaticResource SmallLabelTextStyle}"
                                               Foreground="{StaticResource AccentBrush}"
                                               FontWeight="SemiBold"/>
                                    <TextBlock Text="Upgrade to Pro"
                                               Style="{StaticResource SmallLabelTextStyle}"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <RadioButton GroupName="Navigation"
                                        Content="Settings"
                                        Click="OnNavButtonClick"
                                        Template="{StaticResource NavigationItemTemplate}">
                                <RadioButton.Tag>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="⚙️" FontSize="18" Margin="0,0,12,0"/>
                                        <TextBlock Text="Settings"/>
                                    </StackPanel>
                                </RadioButton.Tag>
                            </RadioButton>

                            <RadioButton GroupName="Navigation"
                                        Content="About"
                                        Click="OnNavButtonClick"
                                        Template="{StaticResource NavigationItemTemplate}">
                                <RadioButton.Tag>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="ℹ️" FontSize="18" Margin="0,0,12,0"/>
                                        <TextBlock Text="About"/>
                                    </StackPanel>
                                </RadioButton.Tag>
                            </RadioButton>

                            <!-- External Links -->
                            <StackPanel Orientation="Horizontal" 
                                       HorizontalAlignment="Center"
                                       Margin="0,16,0,0">
                                <Button Width="36" Height="36"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="8"
                                        Cursor="Hand"
                                        Template="{StaticResource IconButtonTemplate}"
                                        ToolTip="Discord">
                                    <TextBlock Text="💬" FontSize="16"/>
                                </Button>
                                <Button Width="36" Height="36"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Padding="8"
                                        Cursor="Hand"
                                        Template="{StaticResource IconButtonTemplate}"
                                        ToolTip="Website">
                                    <TextBlock Text="🌐" FontSize="16"/>
                                </Button>
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Main Content Area -->
                <Border Grid.Column="1" 
                        Background="{StaticResource PrimaryBackground}"
                        Padding="32">
                    <ContentControl x:Name="ContentArea"/>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>