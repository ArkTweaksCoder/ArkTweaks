<Window x:Class="ArkTweaks.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="clr-namespace:ArkTweaks.UI.Navigation"
        Title="Ark Tweaks" 
        Height="700" 
        Width="1200"
        MinHeight="600"
        MinWidth="1000"
        Background="#1E1E1E"
        WindowStartupLocation="CenterScreen">
    
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" 
                Background="#252526"
                BorderBrush="#3E3E42"
                BorderThickness="0,0,1,0">
            <StackPanel Margin="20">
                <!-- Logo -->
                <TextBlock Text="🧠 Ark Tweaks"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="#FFFFFF"
                           Margin="0,0,0,30"/>

                <!-- Navigation Items -->
                <Button HorizontalAlignment="Stretch"
                        Margin="0,0,0,8"
                        Tag="Dashboard"
                        Click="OnNavButtonClick"
                        Background="#3E3E42"
                        Foreground="#FFFFFF"
                        BorderThickness="0"
                        Padding="12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📊" Margin="0,0,12,0"/>
                        <TextBlock Text="Dashboard"/>
                    </StackPanel>
                </Button>

                <Button HorizontalAlignment="Stretch"
                        Margin="0,0,0,8"
                        Tag="Optimize"
                        Click="OnNavButtonClick"
                        Background="#3E3E42"
                        Foreground="#FFFFFF"
                        BorderThickness="0"
                        Padding="12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚡" Margin="0,0,12,0"/>
                        <TextBlock Text="Optimize"/>
                    </StackPanel>
                </Button>

                <Button HorizontalAlignment="Stretch"
                        Margin="0,0,0,8"
                        Tag="Cleanup"
                        Click="OnNavButtonClick"
                        Background="#3E3E42"
                        Foreground="#FFFFFF"
                        BorderThickness="0"
                        Padding="12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🧹" Margin="0,0,12,0"/>
                        <TextBlock Text="Cleanup"/>
                    </StackPanel>
                </Button>

                <Button HorizontalAlignment="Stretch"
                        Margin="0,0,0,8"
                        Tag="Startup"
                        Click="OnNavButtonClick"
                        Background="#3E3E42"
                        Foreground="#FFFFFF"
                        BorderThickness="0"
                        Padding="12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🚀" Margin="0,0,12,0"/>
                        <TextBlock Text="Startup"/>
                    </StackPanel>
                </Button>

                <Button HorizontalAlignment="Stretch"
                        Margin="0,0,0,8"
                        Tag="Gaming"
                        Click="OnNavButtonClick"
                        Background="#3E3E42"
                        Foreground="#FFFFFF"
                        BorderThickness="0"
                        Padding="12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🎮" Margin="0,0,12,0"/>
                        <TextBlock Text="Gaming"/>
                    </StackPanel>
                </Button>

                <Button HorizontalAlignment="Stretch"
                        Margin="0,0,0,8"
                        Tag="Performance"
                        Click="OnNavButtonClick"
                        Background="#3E3E42"
                        Foreground="#FFFFFF"
                        BorderThickness="0"
                        Padding="12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📈" Margin="0,0,12,0"/>
                        <TextBlock Text="Performance"/>
                    </StackPanel>
                </Button>

                <Button HorizontalAlignment="Stretch"
                        Margin="0,0,0,8"
                        Tag="Restore"
                        Click="OnNavButtonClick"
                        Background="#3E3E42"
                        Foreground="#FFFFFF"
                        BorderThickness="0"
                        Padding="12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🔁" Margin="0,0,12,0"/>
                        <TextBlock Text="Restore"/>
                    </StackPanel>
                </Button>

                <Button HorizontalAlignment="Stretch"
                        Margin="0,0,0,8"
                        Tag="Settings"
                        Click="OnNavButtonClick"
                        Background="#3E3E42"
                        Foreground="#FFFFFF"
                        BorderThickness="0"
                        Padding="12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚙️" Margin="0,0,12,0"/>
                        <TextBlock Text="Settings"/>
                    </StackPanel>
                </Button>

                <Button HorizontalAlignment="Stretch"
                        Margin="0,0,0,8"
                        Tag="About"
                        Click="OnNavButtonClick"
                        Background="#3E3E42"
                        Foreground="#FFFFFF"
                        BorderThickness="0"
                        Padding="12">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="ℹ️" Margin="0,0,12,0"/>
                        <TextBlock Text="About"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <!-- Main Content Area -->
        <Border Grid.Column="1" 
                Background="#1E1E1E"
                Padding="30">
            <ContentControl x:Name="ContentArea"/>
        </Border>
    </Grid>
</Window>