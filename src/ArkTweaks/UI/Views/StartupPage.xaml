<UserControl x:Class="ArkTweaks.UI.Views.StartupPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Startup Manager" 
                       Style="{StaticResource TitleTextStyle}"
                       Margin="0,0,0,8"/>
            <TextBlock Text="Manage applications that launch at startup to improve boot time" 
                       Style="{StaticResource NormalTextStyle}"
                       Foreground="{StaticResource SecondaryTextBrush}"/>
        </StackPanel>

        <!-- Main Content -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Toolbar -->
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBox Width="250"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Padding="12,10"
                                 FontSize="13"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Content="Enable Selected"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding EnableSelectedCommand}"
                                Margin="0,0,8,0"
                                Padding="16,8"
                                FontSize="13"/>

                        <Button Content="Disable Selected"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding DisableSelectedCommand}"
                                Margin="0,0,8,0"
                                Padding="16,8"
                                FontSize="13"/>

                        <Button Content="Add Program"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding AddProgramCommand}"
                                Padding="16,8"
                                FontSize="13"/>
                    </StackPanel>
                </Grid>

                <!-- Startup Items Table -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding StartupItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource ElevatedCardBackground}"
                                        CornerRadius="8"
                                        Padding="16"
                                        Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsEnabled}"
                                                  Margin="0,0,16,0"
                                                  VerticalAlignment="Center"/>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Name}" 
                                                       Style="{StaticResource NormalTextStyle}"
                                                       FontSize="14"
                                                       FontWeight="Medium"/>
                                            <TextBlock Text="{Binding Path}" 
                                                       Style="{StaticResource SmallLabelTextStyle}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,2,0,0"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Publisher}"
                                                   Style="{StaticResource SmallLabelTextStyle}"
                                                   Foreground="{StaticResource SecondaryTextBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,16,0"/>

                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding Status}"
                                                   Style="{StaticResource SmallLabelTextStyle}"
                                                   Foreground="{StaticResource SuccessBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,16,0"/>

                                        <Button Grid.Column="4"
                                                Content="Remove"
                                                Style="{StaticResource DangerButtonStyle}"
                                                Padding="12,6"
                                                FontSize="12"
                                                Command="{Binding RemoveCommand}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Bottom Stats -->
        <Border Grid.Row="2"
                Style="{StaticResource ElevatedCardStyle}"
                Padding="24"
                Margin="0,24,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Total Items" 
                               Style="{StaticResource SmallLabelTextStyle}"
                               Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding TotalItems}" 
                               Style="{StaticResource MetricNumberTextStyle}"
                               FontSize="24"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="Enabled" 
                               Style="{StaticResource SmallLabelTextStyle}"
                               Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding EnabledCount}" 
                               Style="{StaticResource MetricNumberTextStyle}"
                               FontSize="24"
                               Foreground="{StaticResource SuccessBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Disabled" 
                               Style="{StaticResource SmallLabelTextStyle}"
                               Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding DisabledCount}" 
                               Style="{StaticResource MetricNumberTextStyle}"
                               FontSize="24"
                               Foreground="{StaticResource MutedTextBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="3">
                    <TextBlock Text="Boot Impact" 
                               Style="{StaticResource SmallLabelTextStyle}"
                               Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding BootImpact}" 
                               Style="{StaticResource MetricNumberTextStyle}"
                               FontSize="24"
                               Foreground="{StaticResource WarningBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
