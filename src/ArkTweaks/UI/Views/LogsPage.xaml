<UserControl x:Class="ArkTweaks.UI.Views.LogsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Logs" 
                       Style="{StaticResource TitleTextStyle}"
                       Margin="0,0,0,8"/>
            <TextBlock Text="View application logs and diagnostics" 
                       Style="{StaticResource NormalTextStyle}"
                       Foreground="{StaticResource SecondaryTextBrush}"/>
        </StackPanel>

        <!-- Main Content -->
        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Toolbar -->
                <Grid Grid.Row="0" Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBox Width="250"
                                 Style="{StaticResource ModernTextBoxStyle}"
                                 Padding="12,10"
                                 FontSize="13"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <ComboBox Width="150"
                                  Style="{StaticResource ModernTextBoxStyle}"
                                  Padding="12,10"
                                  FontSize="13"
                                  Margin="0,0,8,0"
                                  ItemsSource="{Binding LogLevels}"
                                  SelectedItem="{Binding SelectedLogLevel}"/>

                        <Button Content="Export"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding ExportCommand}"
                                Margin="0,0,8,0"
                                Padding="16,8"
                                FontSize="13"/>

                        <Button Content="Clear Logs"
                                Style="{StaticResource DangerButtonStyle}"
                                Command="{Binding ClearLogsCommand}"
                                Padding="16,8"
                                FontSize="13"/>
                    </StackPanel>
                </Grid>

                <!-- Log Entries -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding LogEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource ElevatedCardBackground}"
                                        CornerRadius="8"
                                        Padding="16"
                                        Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Level}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   Margin="0,0,16,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock" BasedOn="{StaticResource SmallLabelTextStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Level}" Value="ERROR">
                                                            <Setter Property="Foreground" Value="{StaticResource DangerBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Level}" Value="WARN">
                                                            <Setter Property="Foreground" Value="{StaticResource WarningBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Level}" Value="INFO">
                                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Level}" Value="DEBUG">
                                                            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Message}" 
                                                       Style="{StaticResource NormalTextStyle}"
                                                       FontSize="14"
                                                       TextWrapping="Wrap"/>
                                            <TextBlock Text="{Binding Timestamp}" 
                                                       Style="{StaticResource SmallLabelTextStyle}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       Margin="0,4,0,0"/>
                                        </StackPanel>

                                        <Button Grid.Column="2"
                                                Content="Copy"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Padding="12,6"
                                                FontSize="12"
                                                Margin="16,0,0,0"
                                                Command="{Binding CopyCommand}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
