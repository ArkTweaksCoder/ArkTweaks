<UserControl x:Class="ArkTweaks.UI.Views.PerformancePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Performance" 
                       Style="{StaticResource TitleTextStyle}"
                       Margin="0,0,0,8"/>
            <TextBlock Text="Real-time system monitoring and diagnostics" 
                       Style="{StaticResource NormalTextStyle}"
                       Foreground="{StaticResource SecondaryTextBrush}"/>
        </StackPanel>

        <!-- Main Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Top Row: Live Metrics -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- CPU -->
                    <Border Grid.Column="0"
                            Style="{StaticResource CardStyle}"
                            Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="CPU" 
                                       Style="{StaticResource CardTitleTextStyle}"
                                       FontSize="16"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding CpuUsage}" 
                                       Style="{StaticResource MetricNumberTextStyle}"
                                       FontSize="32"
                                       Foreground="{StaticResource AccentBrush}"/>
                            <TextBlock Text="Usage" 
                                       Style="{StaticResource SmallLabelTextStyle}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Margin="0,4,0,0"/>
                            <ProgressBar Value="{Binding CpuUsagePercentage}"
                                         Maximum="100"
                                         Height="4"
                                         Margin="0,8,0,0"
                                         Background="{StaticResource SecondaryBackground}"
                                         Foreground="{StaticResource AccentBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- RAM -->
                    <Border Grid.Column="1"
                            Style="{StaticResource CardStyle}"
                            Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="RAM" 
                                       Style="{StaticResource CardTitleTextStyle}"
                                       FontSize="16"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding RamUsage}" 
                                       Style="{StaticResource MetricNumberTextStyle}"
                                       FontSize="32"
                                       Foreground="{StaticResource AccentBrush}"/>
                            <TextBlock Text="Usage" 
                                       Style="{StaticResource SmallLabelTextStyle}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Margin="0,4,0,0"/>
                            <ProgressBar Value="{Binding RamUsagePercentage}"
                                         Maximum="100"
                                         Height="4"
                                         Margin="0,8,0,0"
                                         Background="{StaticResource SecondaryBackground}"
                                         Foreground="{StaticResource AccentBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Disk -->
                    <Border Grid.Column="2"
                            Style="{StaticResource CardStyle}"
                            Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="Disk" 
                                       Style="{StaticResource CardTitleTextStyle}"
                                       FontSize="16"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding DiskUsage}" 
                                       Style="{StaticResource MetricNumberTextStyle}"
                                       FontSize="32"
                                       Foreground="{StaticResource WarningBrush}"/>
                            <TextBlock Text="Usage" 
                                       Style="{StaticResource SmallLabelTextStyle}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Margin="0,4,0,0"/>
                            <ProgressBar Value="{Binding DiskUsagePercentage}"
                                         Maximum="100"
                                         Height="4"
                                         Margin="0,8,0,0"
                                         Background="{StaticResource SecondaryBackground}"
                                         Foreground="{StaticResource WarningBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Network -->
                    <Border Grid.Column="3"
                            Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Network" 
                                       Style="{StaticResource CardTitleTextStyle}"
                                       FontSize="16"
                                       Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding NetworkSpeed}" 
                                       Style="{StaticResource MetricNumberTextStyle}"
                                       FontSize="32"
                                       Foreground="{StaticResource SuccessBrush}"/>
                            <TextBlock Text="Speed" 
                                       Style="{StaticResource SmallLabelTextStyle}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding NetworkStatus}" 
                                       Style="{StaticResource SmallLabelTextStyle}"
                                       Foreground="{StaticResource SuccessBrush}"
                                       Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Second Row: Detailed Metrics -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- CPU Details -->
                    <Border Grid.Column="0"
                            Style="{StaticResource CardStyle}"
                            Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="CPU Details" 
                                       Style="{StaticResource CardTitleTextStyle}"
                                       FontSize="16"
                                       Margin="0,0,0,16"/>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Temperature" 
                                               Style="{StaticResource SmallLabelTextStyle}"
                                               Foreground="{StaticResource MutedTextBrush}"/>
                                    <TextBlock Text="{Binding CpuTemperature}" 
                                               Style="{StaticResource NormalTextStyle}"
                                               FontSize="18"
                                               Margin="0,4,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Cores" 
                                               Style="{StaticResource SmallLabelTextStyle}"
                                               Foreground="{StaticResource MutedTextBrush}"/>
                                    <TextBlock Text="{Binding CpuCores}" 
                                               Style="{StaticResource NormalTextStyle}"
                                               FontSize="18"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Clock Speed" 
                                               Style="{StaticResource SmallLabelTextStyle}"
                                               Foreground="{StaticResource MutedTextBrush}"/>
                                    <TextBlock Text="{Binding CpuClockSpeed}" 
                                               Style="{StaticResource NormalTextStyle}"
                                               FontSize="18"
                                               Margin="0,4,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Load" 
                                               Style="{StaticResource SmallLabelTextStyle}"
                                               Foreground="{StaticResource MutedTextBrush}"/>
                                    <TextBlock Text="{Binding CpuLoad}" 
                                               Style="{StaticResource NormalTextStyle}"
                                               FontSize="18"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- RAM Details -->
                    <Border Grid.Column="1"
                            Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="RAM Details" 
                                       Style="{StaticResource CardTitleTextStyle}"
                                       FontSize="16"
                                       Margin="0,0,0,16"/>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Total" 
                                               Style="{StaticResource SmallLabelTextStyle}"
                                               Foreground="{StaticResource MutedTextBrush}"/>
                                    <TextBlock Text="{Binding RamTotal}" 
                                               Style="{StaticResource NormalTextStyle}"
                                               FontSize="18"
                                               Margin="0,4,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Available" 
                                               Style="{StaticResource SmallLabelTextStyle}"
                                               Foreground="{StaticResource MutedTextBrush}"/>
                                    <TextBlock Text="{Binding RamAvailable}" 
                                               Style="{StaticResource NormalTextStyle}"
                                               FontSize="18"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Used" 
                                               Style="{StaticResource SmallLabelTextStyle}"
                                               Foreground="{StaticResource MutedTextBrush}"/>
                                    <TextBlock Text="{Binding RamUsed}" 
                                               Style="{StaticResource NormalTextStyle}"
                                               FontSize="18"
                                               Margin="0,4,0,0"/>
                                </StackPanel>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="Cached" 
                                               Style="{StaticResource SmallLabelTextStyle}"
                                               Foreground="{StaticResource MutedTextBrush}"/>
                                    <TextBlock Text="{Binding RamCached}" 
                                               Style="{StaticResource NormalTextStyle}"
                                               FontSize="18"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Third Row: Process List -->
                <TextBlock Text="Top Processes" 
                           Style="{StaticResource SectionHeaderTextStyle}"
                           Margin="0,0,0,16"/>

                <Border Style="{StaticResource CardStyle}">
                    <ItemsControl ItemsSource="{Binding TopProcesses}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource ElevatedCardBackground}"
                                        CornerRadius="8"
                                        Padding="16"
                                        Margin="0,0,0,8">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Name}"
                                                   Style="{StaticResource NormalTextStyle}"
                                                   FontSize="14"
                                                   FontWeight="Medium"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding CpuUsage}"
                                                   Style="{StaticResource SmallLabelTextStyle}"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="16,0,0,0"/>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding RamUsage}"
                                                   Style="{StaticResource SmallLabelTextStyle}"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   VerticalAlignment="Center"
                                                   Margin="16,0,0,0"/>

                                        <Button Grid.Column="3"
                                                Content="End"
                                                Style="{StaticResource DangerButtonStyle}"
                                                Padding="12,6"
                                                FontSize="12"
                                                Margin="16,0,0,0"
                                                Command="{Binding EndProcessCommand}"
                                                CommandParameter="{Binding}"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
