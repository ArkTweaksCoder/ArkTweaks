<UserControl x:Class="ArkTweaks.UI.Views.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Dashboard" 
                       FontSize="32" 
                       FontWeight="Bold"
                       Foreground="#FFFFFF"
                       Margin="0,0,0,20"/>

            <TextBlock Text="System Overview" 
                       FontSize="20" 
                       FontWeight="SemiBold"
                       Foreground="#CCCCCC"
                       Margin="0,0,0,16"/>

            <Border Background="#252526"
                    BorderBrush="#3E3E42"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,0,16">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="8">
                            <TextBlock Text="CPU Usage" 
                                       FontSize="12" 
                                       Foreground="#CCCCCC"/>
                            <TextBlock Text="45%" 
                                       FontSize="24" 
                                       FontWeight="SemiBold"
                                       Foreground="#007ACC"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="8">
                            <TextBlock Text="RAM Usage" 
                                       FontSize="12" 
                                       Foreground="#CCCCCC"/>
                            <TextBlock Text="62%" 
                                       FontSize="24" 
                                       FontWeight="SemiBold"
                                       Foreground="#007ACC"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="8">
                            <TextBlock Text="Storage" 
                                       FontSize="12" 
                                       Foreground="#CCCCCC"/>
                            <TextBlock Text="58%" 
                                       FontSize="24" 
                                       FontWeight="SemiBold"
                                       Foreground="#007ACC"
                                       Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Background="#252526"
                    BorderBrush="#3E3E42"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel>
                    <TextBlock Text="Optimization Score" 
                               FontSize="16" 
                               FontWeight="SemiBold"
                               Foreground="#FFFFFF"/>
                    <TextBlock Text="85/100" 
                               FontSize="48" 
                               FontWeight="Bold"
                               Foreground="#4CAF50"
                               Margin="0,8,0,0"/>
                    <TextBlock Text="Your system is running well" 
                               FontSize="12" 
                               Foreground="#CCCCCC"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
