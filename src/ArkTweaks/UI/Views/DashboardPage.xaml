<UserControl x:Class="ArkTweaks.UI.Views.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,32">
            <!-- Header -->
            <TextBlock Text="Dashboard" 
                       Style="{StaticResource TitleTextStyle}"
                       Margin="0,0,0,32"/>

            <!-- Top Row: Metrics -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Health Score -->
                <Border Grid.Column="0"
                        Style="{StaticResource CardStyle}"
                        Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Health Score" 
                                   Style="{StaticResource SmallLabelTextStyle}"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding HealthScoreDisplay}" 
                                   Style="{StaticResource LargeHealthScoreTextStyle}"/>
                        <TextBlock Text="{Binding HealthStatus}" 
                                   Style="{StaticResource SmallLabelTextStyle}"
                                   Foreground="{StaticResource SuccessBrush}"
                                   Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>

                <!-- CPU -->
                <Border Grid.Column="1"
                        Style="{StaticResource CardStyle}"
                        Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="CPU" 
                                   Style="{StaticResource SmallLabelTextStyle}"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding CpuUsage}" 
                                   Style="{StaticResource MetricNumberTextStyle}"
                                   Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text="Usage" 
                                   Style="{StaticResource SmallLabelTextStyle}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- RAM -->
                <Border Grid.Column="2"
                        Style="{StaticResource CardStyle}"
                        Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="RAM" 
                                   Style="{StaticResource SmallLabelTextStyle}"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding RamUsage}" 
                                   Style="{StaticResource MetricNumberTextStyle}"
                                   Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text="Usage" 
                                   Style="{StaticResource SmallLabelTextStyle}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Disk -->
                <Border Grid.Column="3"
                        Style="{StaticResource CardStyle}"
                        Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Disk" 
                                   Style="{StaticResource SmallLabelTextStyle}"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding DiskUsage}" 
                                   Style="{StaticResource MetricNumberTextStyle}"
                                   Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text="Usage" 
                                   Style="{StaticResource SmallLabelTextStyle}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Power Plan -->
                <Border Grid.Column="4"
                        Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Power Plan" 
                                   Style="{StaticResource SmallLabelTextStyle}"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding PowerPlan}" 
                                   Style="{StaticResource CardTitleTextStyle}"
                                   FontSize="16"
                                   Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding WindowsVersion}" 
                                   Style="{StaticResource SmallLabelTextStyle}"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Second Row: Quick Actions -->
            <TextBlock Text="Quick Actions" 
                       Style="{StaticResource SectionHeaderTextStyle}"
                       Margin="0,0,0,16"/>

            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Content="Optimize"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Command="{Binding OptimizeCommand}"
                        Margin="0,0,12,0"/>

                <Button Grid.Column="1"
                        Content="Cleanup"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding CleanupCommand}"
                        Margin="0,0,12,0"/>

                <Button Grid.Column="2"
                        Content="Refresh"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding RefreshCommand}"
                        Margin="0,0,12,0"/>

                <Button Grid.Column="3"
                        Content="Restore Point"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding RestorePointCommand}"/>
            </Grid>

            <!-- Third Row: Recommendations -->
            <TextBlock Text="Recommendations" 
                       Style="{StaticResource SectionHeaderTextStyle}"
                       Margin="0,0,0,16"/>

            <Border Style="{StaticResource CardStyle}"
                    Margin="0,0,0,24">
                <StackPanel>
                    <ItemsControl ItemsSource="{Binding Recommendations}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{StaticResource ElevatedCardBackground}"
                                        CornerRadius="12"
                                        Padding="16"
                                        Margin="0,0,0,12">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Title}" 
                                                       Style="{StaticResource CardTitleTextStyle}"
                                                       FontSize="16"
                                                       Margin="0,0,0,4"/>
                                            <TextBlock Text="{Binding Description}" 
                                                       Style="{StaticResource NormalTextStyle}"
                                                       FontSize="13"
                                                       Foreground="{StaticResource SecondaryTextBrush}"/>
                                        </StackPanel>

                                        <Button Grid.Column="1"
                                                Content="Apply"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                Padding="16,8"
                                                FontSize="13"
                                                Margin="12,0,0,0"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <TextBlock Text="No recommendations available" 
                               Style="{StaticResource SmallLabelTextStyle}"
                               Foreground="{StaticResource MutedTextBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,16,0,0"
                               Visibility="{Binding HasRecommendations, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                </StackPanel>
            </Border>

            <!-- Fourth Row: Performance History Preview -->
            <TextBlock Text="Performance History" 
                       Style="{StaticResource SectionHeaderTextStyle}"
                       Margin="0,0,0,16"/>

            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource CardStyle}"
                        Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Health Trend" 
                                   Style="{StaticResource CardTitleTextStyle}"
                                   FontSize="16"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding HealthTrend}" 
                                   Style="{StaticResource MetricNumberTextStyle}"
                                   FontSize="24"
                                   Foreground="{StaticResource SuccessBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Style="{StaticResource CardStyle}"
                        Margin="0,0,12,0">
                    <StackPanel>
                        <TextBlock Text="Cleanup Trend" 
                                   Style="{StaticResource CardTitleTextStyle}"
                                   FontSize="16"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding CleanupTrend}" 
                                   Style="{StaticResource MetricNumberTextStyle}"
                                   FontSize="24"
                                   Foreground="{StaticResource AccentBrush}"/>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource CardStyle}">
                    <StackPanel>
                        <TextBlock Text="Storage Trend" 
                                   Style="{StaticResource CardTitleTextStyle}"
                                   FontSize="16"
                                   Margin="0,0,0,8"/>
                        <TextBlock Text="{Binding StorageTrend}" 
                                   Style="{StaticResource MetricNumberTextStyle}"
                                   FontSize="24"
                                   Foreground="{StaticResource WarningBrush}"/>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- Bottom: Recent Activity -->
            <TextBlock Text="Recent Activity" 
                       Style="{StaticResource SectionHeaderTextStyle}"
                       Margin="0,0,0,16"/>

            <Border Style="{StaticResource CardStyle}">
                <ItemsControl ItemsSource="{Binding RecentActivity}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding Icon}"
                                           FontSize="16"
                                           Margin="0,0,12,0"/>

                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding Title}" 
                                               Style="{StaticResource NormalTextStyle}"
                                               FontSize="14"/>
                                    <TextBlock Text="{Binding Timestamp}" 
                                               Style="{StaticResource SmallLabelTextStyle}"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>

                                <TextBlock Grid.Column="2"
                                           Text="{Binding Status}"
                                           Style="{StaticResource SmallLabelTextStyle}"
                                           Foreground="{StaticResource SuccessBrush}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
