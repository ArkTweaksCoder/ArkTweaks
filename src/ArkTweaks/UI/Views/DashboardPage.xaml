<UserControl x:Class="ArkTweaks.UI.Views.DashboardPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Dashboard" 
                       FontSize="{StaticResource FontSizeXXLarge}" 
                       FontWeight="{StaticResource FontWeightBold}"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Margin="0,0,0,{StaticResource SpacingL}"/>

            <TextBlock Text="System Overview" 
                       FontSize="{StaticResource FontSizeLarge}" 
                       FontWeight="{StaticResource FontWeightSemiBold}"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       Margin="0,0,0,{StaticResource SpacingM}"/>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,{StaticResource SpacingM}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="{StaticResource SpacingS}">
                            <TextBlock Text="CPU Usage" 
                                       FontSize="{StaticResource FontSizeSmall}" 
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="45%" 
                                       FontSize="{StaticResource FontSizeXLarge}" 
                                       FontWeight="{StaticResource FontWeightSemiBold}"
                                       Foreground="{StaticResource AccentBrush}"
                                       Margin="0,{StaticResource SpacingXS},0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="{StaticResource SpacingS}">
                            <TextBlock Text="RAM Usage" 
                                       FontSize="{StaticResource FontSizeSmall}" 
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="62%" 
                                       FontSize="{StaticResource FontSizeXLarge}" 
                                       FontWeight="{StaticResource FontWeightSemiBold}"
                                       Foreground="{StaticResource AccentBrush}"
                                       Margin="0,{StaticResource SpacingXS},0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2" Margin="{StaticResource SpacingS}">
                            <TextBlock Text="Storage" 
                                       FontSize="{StaticResource FontSizeSmall}" 
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="58%" 
                                       FontSize="{StaticResource FontSizeXLarge}" 
                                       FontWeight="{StaticResource FontWeightSemiBold}"
                                       Foreground="{StaticResource AccentBrush}"
                                       Margin="0,{StaticResource SpacingXS},0,0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Optimization Score" 
                               FontSize="{StaticResource FontSizeMedium}" 
                               FontWeight="{StaticResource FontWeightSemiBold}"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="85/100" 
                               FontSize="{StaticResource FontSizeHuge}" 
                               FontWeight="{StaticResource FontWeightBold}"
                               Foreground="{StaticResource SuccessBrush}"
                               Margin="0,{StaticResource SpacingS},0,0"/>
                    <TextBlock Text="Your system is running well" 
                               FontSize="{StaticResource FontSizeSmall}" 
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,{StaticResource SpacingXS},0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
