<UserControl x:Class="ArkTweaks.UI.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Settings" 
                       Style="{StaticResource TitleTextStyle}"
                       Margin="0,0,0,8"/>
            <TextBlock Text="Configure application preferences and license" 
                       Style="{StaticResource NormalTextStyle}"
                       Foreground="{StaticResource SecondaryTextBrush}"/>
        </StackPanel>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="240"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Category Navigation -->
            <Border Grid.Column="0"
                    Style="{StaticResource CardStyle}"
                    Margin="0,0,16,0">
                <StackPanel>
                    <TextBlock Text="Categories" 
                               Style="{StaticResource CardTitleTextStyle}"
                               Margin="0,0,0,16"/>

                    <ItemsControl ItemsSource="{Binding SettingsCategories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="Transparent"
                                        CornerRadius="8"
                                        Padding="12"
                                        Margin="0,0,0,4"
                                        Cursor="Hand">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Icon}"
                                                   FontSize="16"
                                                   Margin="0,0,12,0"/>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Name}"
                                                   Style="{StaticResource NormalTextStyle}"
                                                   FontSize="14"
                                                   FontWeight="Medium"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Settings Content -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <!-- License Section -->
                    <Border Style="{StaticResource CardStyle}"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="License" 
                                       Style="{StaticResource CardTitleTextStyle}"
                                       FontSize="18"
                                       Margin="0,0,0,16"/>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Current Tier" 
                                               Style="{StaticResource SmallLabelTextStyle}"
                                               Foreground="{StaticResource MutedTextBrush}"/>
                                    <TextBlock Text="{Binding CurrentLicenseTier}" 
                                               Style="{StaticResource NormalTextStyle}"
                                               FontSize="16"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource AccentBrush}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>

                                <Button Grid.Column="1"
                                        Content="Upgrade"
                                        Style="{StaticResource PrimaryButtonStyle}"
                                        Command="{Binding UpgradeLicenseCommand}"/>
                            </Grid>

                            <TextBlock Text="License Key" 
                                       Style="{StaticResource SmallLabelTextStyle}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       Margin="0,0,0,8"/>
                            <TextBox Style="{StaticResource ModernTextBoxStyle}"
                                     Text="{Binding LicenseKey}"
                                     Margin="0,0,0,12"/>
                            <Button Content="Activate License"
                                    Style="{StaticResource SecondaryButtonStyle}"
                                    Command="{Binding ActivateLicenseCommand}"
                                    HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>

                    <!-- General Settings -->
                    <Border Style="{StaticResource CardStyle}"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="General" 
                                       Style="{StaticResource CardTitleTextStyle}"
                                       FontSize="18"
                                       Margin="0,0,0,16"/>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Start with Windows" 
                                               Style="{StaticResource NormalTextStyle}"
                                               FontSize="14"/>
                                    <TextBlock Text="Launch application at system startup" 
                                               Style="{StaticResource SmallLabelTextStyle}"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>

                                <CheckBox Grid.Column="1"
                                          IsChecked="{Binding StartWithWindows}"
                                          Template="{StaticResource ToggleSwitchTemplate}"/>
                            </Grid>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Minimize to Tray" 
                                               Style="{StaticResource NormalTextStyle}"
                                               FontSize="14"/>
                                    <TextBlock Text="Minimize to system tray instead of taskbar" 
                                               Style="{StaticResource SmallLabelTextStyle}"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>

                                <CheckBox Grid.Column="1"
                                          IsChecked="{Binding MinimizeToTray}"
                                          Template="{StaticResource ToggleSwitchTemplate}"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Auto-Update" 
                                               Style="{StaticResource NormalTextStyle}"
                                               FontSize="14"/>
                                    <TextBlock Text="Automatically check for updates" 
                                               Style="{StaticResource SmallLabelTextStyle}"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>

                                <CheckBox Grid.Column="1"
                                          IsChecked="{Binding AutoUpdate}"
                                          Template="{StaticResource ToggleSwitchTemplate}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Notifications -->
                    <Border Style="{StaticResource CardStyle}"
                            Margin="0,0,0,16">
                        <StackPanel>
                            <TextBlock Text="Notifications" 
                                       Style="{StaticResource CardTitleTextStyle}"
                                       FontSize="18"
                                       Margin="0,0,0,16"/>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Enable Notifications" 
                                               Style="{StaticResource NormalTextStyle}"
                                               FontSize="14"/>
                                    <TextBlock Text="Show desktop notifications" 
                                               Style="{StaticResource SmallLabelTextStyle}"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>

                                <CheckBox Grid.Column="1"
                                          IsChecked="{Binding EnableNotifications}"
                                          Template="{StaticResource ToggleSwitchTemplate}"/>
                            </Grid>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Sound Effects" 
                                               Style="{StaticResource NormalTextStyle}"
                                               FontSize="14"/>
                                    <TextBlock Text="Play sounds on actions" 
                                               Style="{StaticResource SmallLabelTextStyle}"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>

                                <CheckBox Grid.Column="1"
                                          IsChecked="{Binding SoundEffects}"
                                          Template="{StaticResource ToggleSwitchTemplate}"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Privacy -->
                    <Border Style="{StaticResource CardStyle}">
                        <StackPanel>
                            <TextBlock Text="Privacy" 
                                       Style="{StaticResource CardTitleTextStyle}"
                                       FontSize="18"
                                       Margin="0,0,0,16"/>

                            <Grid Margin="0,0,0,16">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="Telemetry" 
                                               Style="{StaticResource NormalTextStyle}"
                                               FontSize="14"/>
                                    <TextBlock Text="Send anonymous usage data" 
                                               Style="{StaticResource SmallLabelTextStyle}"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>

                                <CheckBox Grid.Column="1"
                                          IsChecked="{Binding Telemetry}"
                                          Template="{StaticResource ToggleSwitchTemplate}"/>
                            </Grid>

                            <Button Content="Clear All Data"
                                    Style="{StaticResource DangerButtonStyle}"
                                    Command="{Binding ClearAllDataCommand}"
                                    HorizontalAlignment="Left"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
