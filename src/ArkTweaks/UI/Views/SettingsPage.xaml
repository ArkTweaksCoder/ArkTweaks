<UserControl x:Class="ArkTweaks.UI.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Settings" 
                       FontSize="{StaticResource FontSizeXXLarge}" 
                       FontWeight="{StaticResource FontWeightBold}"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Margin="0,0,0,{StaticResource SpacingL}"/>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,{StaticResource SpacingM}">
                <StackPanel>
                    <TextBlock Text="License" 
                               FontSize="{StaticResource FontSizeLarge}" 
                               FontWeight="{StaticResource FontWeightSemiBold}"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Current Tier: Free" 
                               FontSize="{StaticResource FontSizeNormal}" 
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,{StaticResource SpacingS},0,0"/>
                    <TextBox x:Name="LicenseKeyInput" 
                             Width="300" 
                             Height="32" 
                             Margin="0,{StaticResource SpacingM},0,{StaticResource SpacingS}"
                             Background="{StaticResource CardBrush}"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             BorderBrush="{StaticResource BorderBrush}"
                             Padding="8"/>
                    <Button Content="Activate License" 
                            Style="{StaticResource PrimaryButton}" 
                            HorizontalAlignment="Left"
                            Margin="0,{StaticResource SpacingS},0,0"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="About License Tiers" 
                               FontSize="{StaticResource FontSizeMedium}" 
                               FontWeight="{StaticResource FontWeightSemiBold}"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="• Free: Basic cleanup and startup management" 
                               FontSize="{StaticResource FontSizeSmall}" 
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,{StaticResource SpacingXS},0,0"/>
                    <TextBlock Text="• Standard: Recycle bin cleanup, visual effects" 
                               FontSize="{StaticResource FontSizeSmall}" 
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,{StaticResource SpacingXS},0,0"/>
                    <TextBlock Text="• Pro: Browser cache, GPU scheduling, DNS tools" 
                               FontSize="{StaticResource FontSizeSmall}" 
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,{StaticResource SpacingXS},0,0"/>
                    <TextBlock Text="• Ultimate: Diagnostics, automation, gaming profiles" 
                               FontSize="{StaticResource FontSizeSmall}" 
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,{StaticResource SpacingXS},0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
