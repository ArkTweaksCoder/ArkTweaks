<UserControl x:Class="ArkTweaks.UI.Views.SettingsPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Settings" 
                       FontSize="32" 
                       FontWeight="Bold"
                       Foreground="#FFFFFF"
                       Margin="0,0,0,20"/>

            <Border Background="#252526"
                    BorderBrush="#3E3E42"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="License" 
                               FontSize="20" 
                               FontWeight="SemiBold"
                               Foreground="#FFFFFF"/>
                    <TextBlock Text="Current Tier: Free" 
                               FontSize="14" 
                               Foreground="#CCCCCC"
                               Margin="0,8,0,0"/>
                    <TextBox x:Name="LicenseKeyInput" 
                             Width="300" 
                             Height="32" 
                             Margin="0,16,0,8"
                             Background="#1E1E1E"
                             Foreground="#FFFFFF"
                             BorderBrush="#3E3E42"
                             Padding="8"/>
                    <Button Content="Activate License" 
                            Background="#007ACC"
                            Foreground="#FFFFFF"
                            BorderThickness="0"
                            Padding="12,8"
                            HorizontalAlignment="Left"
                            Margin="0,8,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="#252526"
                    BorderBrush="#3E3E42"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel>
                    <TextBlock Text="About License Tiers" 
                               FontSize="16" 
                               FontWeight="SemiBold"
                               Foreground="#FFFFFF"/>
                    <TextBlock Text="• Free: Basic cleanup and startup management" 
                               FontSize="12" 
                               Foreground="#CCCCCC"
                               Margin="0,4,0,0"/>
                    <TextBlock Text="• Standard: Recycle bin cleanup, visual effects" 
                               FontSize="12" 
                               Foreground="#CCCCCC"
                               Margin="0,4,0,0"/>
                    <TextBlock Text="• Pro: Browser cache, GPU scheduling, DNS tools" 
                               FontSize="12" 
                               Foreground="#CCCCCC"
                               Margin="0,4,0,0"/>
                    <TextBlock Text="• Ultimate: Diagnostics, automation, gaming profiles" 
                               FontSize="12" 
                               Foreground="#CCCCCC"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
