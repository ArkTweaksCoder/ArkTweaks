<UserControl x:Class="ArkTweaks.UI.Views.AboutPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="About" 
                       FontSize="32" 
                       FontWeight="Bold"
                       Foreground="#FFFFFF"
                       Margin="0,0,0,20"/>

            <Border Background="#252526"
                    BorderBrush="#3E3E42"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel>
                    <TextBlock Text="🧠 Ark Tweaks" 
                               FontSize="48" 
                               FontWeight="Bold"
                               Foreground="#007ACC"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="Version 1.0.0" 
                               FontSize="20" 
                               FontWeight="SemiBold"
                               Foreground="#FFFFFF"
                               Margin="0,0,0,16"/>
                    <TextBlock Text="A Windows optimization tool built for gamers and performance-focused users." 
                               FontSize="14" 
                               Foreground="#CCCCCC"
                               Margin="0,0,0,8"
                               TextWrapping="Wrap"/>
                    <TextBlock Text="Features:" 
                               FontSize="16" 
                               FontWeight="SemiBold"
                               Foreground="#FFFFFF"
                               Margin="0,0,0,8"/>
                    <TextBlock Text="• Safe, transparent system optimizations" 
                               FontSize="12" 
                               Foreground="#CCCCCC"
                               Margin="0,4,0,0"/>
                    <TextBlock Text="• Reversible tweaks with restore points" 
                               FontSize="12" 
                               Foreground="#CCCCCC"
                               Margin="0,4,0,0"/>
                    <TextBlock Text="• License-based feature access" 
                               FontSize="12" 
                               Foreground="#CCCCCC"
                               Margin="0,4,0,0"/>
                    <TextBlock Text="• Modern dark UI" 
                               FontSize="12" 
                               Foreground="#CCCCCC"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
