<UserControl x:Class="ArkTweaks.UI.Views.OptimizePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Optimize" 
                       FontSize="32" 
                       FontWeight="Bold"
                       Foreground="#FFFFFF"
                       Margin="0,0,0,20"/>

            <Border Background="#252526"
                    BorderBrush="#3E3E42"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel>
                    <TextBlock Text="System Optimization" 
                               FontSize="20" 
                               FontWeight="SemiBold"
                               Foreground="#FFFFFF"/>
                    <TextBlock Text="Advanced optimization features will be available in future updates." 
                               FontSize="14" 
                               Foreground="#CCCCCC"
                               Margin="0,8,0,0"/>
                    <TextBlock Text="Current version includes basic cleanup and startup management." 
                               FontSize="12" 
                               Foreground="#888888"
                       Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
