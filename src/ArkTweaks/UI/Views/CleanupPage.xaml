<UserControl x:Class="ArkTweaks.UI.Views.CleanupPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,24">
            <TextBlock Text="Cleanup" 
                       Style="{StaticResource TitleTextStyle}"
                       Margin="0,0,0,8"/>
            <TextBlock Text="Scan and clean unnecessary files to free up disk space" 
                       Style="{StaticResource NormalTextStyle}"
                       Foreground="{StaticResource SecondaryTextBrush}"/>
        </StackPanel>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Categories -->
            <Border Grid.Column="0"
                    Style="{StaticResource CardStyle}"
                    Margin="0,0,16,0">
                <StackPanel>
                    <TextBlock Text="Categories" 
                               Style="{StaticResource CardTitleTextStyle}"
                               Margin="0,0,0,16"/>

                    <ItemsControl ItemsSource="{Binding CleanupCategories}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="Transparent"
                                        CornerRadius="8"
                                        Padding="12"
                                        Margin="0,0,0,8"
                                        Cursor="Hand">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsSelected}"
                                                  Margin="0,0,12,0"/>

                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Name}" 
                                                       Style="{StaticResource NormalTextStyle}"
                                                       FontSize="14"/>
                                            <TextBlock Style="{StaticResource SmallLabelTextStyle}"
                                                       Foreground="{StaticResource MutedTextBrush}"
                                                       Margin="0,2,0,0">
                                                <Run Text="{Binding FileCount}"/>
                                                <Run Text=" files"/>
                                            </TextBlock>
                                        </StackPanel>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Size}"
                                                   Style="{StaticResource SmallLabelTextStyle}"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>
            </Border>

            <!-- Files List -->
            <Border Grid.Column="1"
                    Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Margin="0,0,0,16">
                        <TextBlock Text="Files" 
                                   Style="{StaticResource CardTitleTextStyle}"
                                   Margin="0,0,0,8"/>
                        <TextBlock Style="{StaticResource SmallLabelTextStyle}"
                                   Foreground="{StaticResource MutedTextBrush}">
                            <Run Text="{Binding TotalFiles}"/>
                            <Run Text=" files found"/>
                        </TextBlock>
                    </StackPanel>

                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding CleanupFiles}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="{StaticResource ElevatedCardBackground}"
                                            CornerRadius="8"
                                            Padding="12"
                                            Margin="0,0,0,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <TextBlock Grid.Column="0"
                                                       Text="{Binding Icon}"
                                                       FontSize="16"
                                                       Margin="0,0,12,0"/>

                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Name}" 
                                                           Style="{StaticResource NormalTextStyle}"
                                                           FontSize="14"/>
                                                <TextBlock Text="{Binding Path}" 
                                                           Style="{StaticResource SmallLabelTextStyle}"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding Size}"
                                                       Style="{StaticResource SmallLabelTextStyle}"
                                                       Foreground="{StaticResource SecondaryTextBrush}"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Bottom Actions -->
        <Border Grid.Row="2"
                Style="{StaticResource ElevatedCardStyle}"
                Padding="24"
                Margin="0,24,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Estimated Space to Reclaim" 
                               Style="{StaticResource SmallLabelTextStyle}"
                               Foreground="{StaticResource MutedTextBrush}"/>
                    <TextBlock Text="{Binding EstimatedReclaimedSpace}" 
                               Style="{StaticResource MetricNumberTextStyle}"
                               FontSize="28"
                               Foreground="{StaticResource SuccessBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="1" 
                          Orientation="Horizontal">
                    <Button Content="Scan"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding ScanCommand}"
                            Margin="0,0,12,0"/>

                    <Button Content="Clean Selected"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Command="{Binding CleanSelectedCommand}"
                            Margin="0,0,12,0"/>

                    <Button Content="Clean All"
                            Style="{StaticResource DangerButtonStyle}"
                            Command="{Binding CleanAllCommand}"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
