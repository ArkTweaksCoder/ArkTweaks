<UserControl x:Class="ArkTweaks.UI.Views.CleanupPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Cleanup" 
                       FontSize="{StaticResource FontSizeXXLarge}" 
                       FontWeight="{StaticResource FontWeightBold}"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Margin="0,0,0,{StaticResource SpacingL}"/>

            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,{StaticResource SpacingM}">
                <StackPanel>
                    <TextBlock Text="Temporary Files" 
                               FontSize="{StaticResource FontSizeLarge}" 
                               FontWeight="{StaticResource FontWeightSemiBold}"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Clean up temporary files to free disk space." 
                               FontSize="{StaticResource FontSizeNormal}" 
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,{StaticResource SpacingS},0,0"/>
                    <Button Content="Scan Temp Files" 
                            Style="{StaticResource PrimaryButton}" 
                            HorizontalAlignment="Left"
                            Margin="0,{StaticResource SpacingM},0,0"/>
                </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Recycle Bin" 
                               FontSize="{StaticResource FontSizeLarge}" 
                               FontWeight="{StaticResource FontWeightSemiBold}"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Empty recycle bin (Standard tier feature)" 
                               FontSize="{StaticResource FontSizeNormal}" 
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,{StaticResource SpacingS},0,0"/>
                    <Button Content="Empty Recycle Bin" 
                            Style="{StaticResource SecondaryButton}" 
                            HorizontalAlignment="Left"
                            IsEnabled="False"
                            Margin="0,{StaticResource SpacingM},0,0"/>
                    <TextBlock Text="⚠️ Requires Standard license" 
                               FontSize="{StaticResource FontSizeSmall}" 
                               Foreground="{StaticResource WarningBrush}"
                               Margin="0,{StaticResource SpacingXS},0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
