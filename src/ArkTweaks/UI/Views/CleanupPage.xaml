<UserControl x:Class="ArkTweaks.UI.Views.CleanupPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Cleanup" 
                       FontSize="32" 
                       FontWeight="Bold"
                       Foreground="#FFFFFF"
                       Margin="0,0,0,20"/>

            <Border Background="#252526"
                    BorderBrush="#3E3E42"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16"
                    Margin="0,0,0,16">
                <StackPanel>
                    <TextBlock Text="Temporary Files" 
                               FontSize="20" 
                               FontWeight="SemiBold"
                               Foreground="#FFFFFF"/>
                    <TextBlock Text="Clean up temporary files to free disk space." 
                               FontSize="14" 
                               Foreground="#CCCCCC"
                               Margin="0,8,0,0"/>
                    <Button Content="Scan Temp Files" 
                            Background="#007ACC"
                            Foreground="#FFFFFF"
                            BorderThickness="0"
                            Padding="12,8"
                            HorizontalAlignment="Left"
                            Margin="0,16,0,0"/>
                </StackPanel>
            </Border>

            <Border Background="#252526"
                    BorderBrush="#3E3E42"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel>
                    <TextBlock Text="Recycle Bin" 
                               FontSize="20" 
                               FontWeight="SemiBold"
                               Foreground="#FFFFFF"/>
                    <TextBlock Text="Empty recycle bin (Standard tier feature)" 
                               FontSize="14" 
                               Foreground="#CCCCCC"
                               Margin="0,8,0,0"/>
                    <Button Content="Empty Recycle Bin" 
                            Background="#3E3E42"
                            Foreground="#FFFFFF"
                            BorderThickness="0"
                            Padding="12,8"
                            HorizontalAlignment="Left"
                            IsEnabled="False"
                            Margin="0,16,0,0"/>
                    <TextBlock Text="⚠️ Requires Standard license" 
                               FontSize="12" 
                               Foreground="#FF9800"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
