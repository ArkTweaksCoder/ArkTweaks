<UserControl x:Class="ArkTweaks.UI.Views.GamingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Gaming" 
                       FontSize="{StaticResource FontSizeXXLarge}" 
                       FontWeight="{StaticResource FontWeightBold}"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Margin="0,0,0,{StaticResource SpacingL}"/>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Gaming Profiles" 
                               FontSize="{StaticResource FontSizeLarge}" 
                               FontWeight="{StaticResource FontWeightSemiBold}"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Gaming profiles and optimizations (Ultimate tier feature)" 
                               FontSize="{StaticResource FontSizeNormal}" 
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,{StaticResource SpacingS},0,0"/>
                    <TextBlock Text="⚠️ Requires Ultimate license" 
                               FontSize="{StaticResource FontSizeSmall}" 
                               Foreground="{StaticResource WarningBrush}"
                               Margin="0,{StaticResource SpacingXS},0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
