<UserControl x:Class="ArkTweaks.UI.Views.GamingPage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="Gaming" 
                       FontSize="32" 
                       FontWeight="Bold"
                       Foreground="#FFFFFF"
                       Margin="0,0,0,20"/>

            <Border Background="#252526"
                    BorderBrush="#3E3E42"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel>
                    <TextBlock Text="Gaming Profiles" 
                               FontSize="20" 
                               FontWeight="SemiBold"
                               Foreground="#FFFFFF"/>
                    <TextBlock Text="Gaming profiles and optimizations (Ultimate tier feature)" 
                               FontSize="14" 
                               Foreground="#CCCCCC"
                               Margin="0,8,0,0"/>
                    <TextBlock Text="⚠️ Requires Ultimate license" 
                               FontSize="12" 
                               Foreground="#FF9800"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
