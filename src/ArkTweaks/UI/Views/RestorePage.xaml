<UserControl x:Class="ArkTweaks.UI.Views.RestorePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="System Restore" 
                       FontSize="{StaticResource FontSizeXXLarge}" 
                       FontWeight="{StaticResource FontWeightBold}"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       Margin="0,0,0,{StaticResource SpacingL}"/>

            <Border Style="{StaticResource CardStyle}">
                <StackPanel>
                    <TextBlock Text="Create Restore Point" 
                               FontSize="{StaticResource FontSizeLarge}" 
                               FontWeight="{StaticResource FontWeightSemiBold}"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <TextBlock Text="Create a system restore point before making changes." 
                               FontSize="{StaticResource FontSizeNormal}" 
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,{StaticResource SpacingS},0,0"/>
                    <Button Content="Create Restore Point" 
                            Style="{StaticResource PrimaryButton}" 
                            HorizontalAlignment="Left"
                            Margin="0,{StaticResource SpacingM},0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
