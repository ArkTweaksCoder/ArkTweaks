<UserControl x:Class="ArkTweaks.UI.Views.RestorePage"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <TextBlock Text="System Restore" 
                       FontSize="32" 
                       FontWeight="Bold"
                       Foreground="#FFFFFF"
                       Margin="0,0,0,20"/>

            <Border Background="#252526"
                    BorderBrush="#3E3E42"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel>
                    <TextBlock Text="Create Restore Point" 
                               FontSize="20" 
                               FontWeight="SemiBold"
                               Foreground="#FFFFFF"/>
                    <TextBlock Text="Create a system restore point before making changes." 
                               FontSize="14" 
                               Foreground="#CCCCCC"
                               Margin="0,8,0,0"/>
                    <Button Content="Create Restore Point" 
                            Background="#007ACC"
                            Foreground="#FFFFFF"
                            BorderThickness="0"
                            Padding="12,8"
                            HorizontalAlignment="Left"
                            Margin="0,16,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
