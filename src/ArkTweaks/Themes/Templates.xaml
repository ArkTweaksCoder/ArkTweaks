<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Drop Shadow Effects -->
    <DropShadowEffect x:Key="CardShadow" 
                      Color="#000000" 
                      Opacity="0.15" 
                      BlurRadius="16" 
                      ShadowDepth="0" />
    
    <DropShadowEffect x:Key="ButtonShadow" 
                      Color="#000000" 
                      Opacity="0.2" 
                      BlurRadius="8" 
                      ShadowDepth="2" />
    
    <DropShadowEffect x:Key="GlowEffect" 
                      Color="#4F8CFF" 
                      Opacity="0.3" 
                      BlurRadius="20" 
                      ShadowDepth="0" />

    <!-- Icon Button Template -->
    <ControlTemplate x:Key="IconButtonTemplate" TargetType="Button">
        <Border x:Name="Border"
                Background="Transparent"
                CornerRadius="20"
                Width="40"
                Height="40"
                Padding="8">
            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Border" Property="Background" Value="{StaticResource HoverBrush}" />
                <Setter TargetName="Border" Property="Effect" Value="{StaticResource GlowEffect}" />
            </Trigger>
            <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="Border" Property="Background" Value="{StaticResource PressedBrush}" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- Navigation Item Template -->
    <ControlTemplate x:Key="NavigationItemTemplate" TargetType="RadioButton">
        <Grid x:Name="RootGrid" 
              Background="Transparent" 
              Height="48" 
              Margin="8,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            
            <!-- Selection Indicator -->
            <Border x:Name="SelectionIndicator"
                    Grid.Column="0"
                    Width="4"
                    Height="24"
                    Margin="0,0,12,0"
                    Background="{StaticResource AccentBrush}"
                    CornerRadius="2"
                    Opacity="0"
                    HorizontalAlignment="Left" />
            
            <!-- Icon -->
            <ContentPresenter x:Name="IconPresenter"
                            Grid.Column="0"
                            Content="{TemplateBinding Tag}"
                            Margin="0,0,16,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Opacity="0.7" />
            
            <!-- Label -->
            <TextBlock x:Name="Label"
                       Grid.Column="1"
                       Text="{TemplateBinding Content}"
                       FontFamily="Segoe UI Variable"
                       FontSize="15"
                       FontWeight="Medium"
                       Foreground="{StaticResource SecondaryTextBrush}"
                       VerticalAlignment="Center" />
        </Grid>
        
        <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="SelectionIndicator" Property="Opacity" Value="1" />
                <Setter TargetName="IconPresenter" Property="Opacity" Value="1" />
                <Setter TargetName="Label" Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
                <Setter TargetName="RootGrid" Property="Background" Value="{StaticResource HoverBrush}" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="RootGrid" Property="Background" Value="{StaticResource HoverBrush}" />
                <Setter TargetName="IconPresenter" Property="Opacity" Value="1" />
                <Setter TargetName="Label" Property="Foreground" Value="{StaticResource PrimaryTextBrush}" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- Toggle Switch Template -->
    <ControlTemplate x:Key="ToggleSwitchTemplate" TargetType="CheckBox">
        <Grid Width="48" Height="24">
            <Border x:Name="TrackBackground"
                    Background="{StaticResource SecondaryBackground}"
                    CornerRadius="12"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1" />
            
            <Ellipse x:Name="Thumb"
                     Width="18"
                     Height="18"
                     Fill="{StaticResource MutedTextBrush}"
                     HorizontalAlignment="Left"
                     Margin="3">
                <Ellipse.RenderTransform>
                    <TranslateTransform x:Name="ThumbTransform" X="0" />
                </Ellipse.RenderTransform>
            </Ellipse>
        </Grid>
        
        <ControlTemplate.Triggers>
            <Trigger Property="IsChecked" Value="True">
                <Trigger.EnterActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="ThumbTransform"
                                           Storyboard.TargetProperty="X"
                                           To="24"
                                           Duration="0:0:0.2"
                                           EasingFunction="{StaticResource EaseOutQuad}" />
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.EnterActions>
                <Trigger.ExitActions>
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetName="ThumbTransform"
                                           Storyboard.TargetProperty="X"
                                           To="0"
                                           Duration="0:0:0.2"
                                           EasingFunction="{StaticResource EaseOutQuad}" />
                        </Storyboard>
                    </BeginStoryboard>
                </Trigger.ExitActions>
                <Setter TargetName="TrackBackground" Property="Background" Value="{StaticResource AccentBrush}" />
                <Setter TargetName="TrackBackground" Property="BorderBrush" Value="Transparent" />
                <Setter TargetName="Thumb" Property="Fill" Value="White" />
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- Recommendation Card Template -->
    <ControlTemplate x:Key="RecommendationCardTemplate" TargetType="Border">
        <Border Background="{TemplateBinding Background}"
                BorderBrush="{TemplateBinding BorderBrush}"
                BorderThickness="{TemplateBinding BorderThickness}"
                CornerRadius="{TemplateBinding CornerRadius}">
            <ContentPresenter />
        </Border>
    </ControlTemplate>

